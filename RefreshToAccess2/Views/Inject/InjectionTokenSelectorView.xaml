<Window x:Class="RefreshToAccess2.Views.Inject.InjectionTokenSelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Select Token for Injection"
        Height="380" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="28">

        <!-- Heading -->
        <TextBlock Text="Select Token for Injection"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,20"/>

        <!-- Tab control: stored token vs custom token -->
        <TabControl x:Name="SelectorTab"
                    Height="160"
                    md:ColorZoneAssist.Mode="PrimaryMid">

            <!-- Tab 1 – pick from stored alts -->
            <TabItem Header="Stored Account">
                <Grid Margin="8,16,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Only accounts with a non-expired access token are listed."
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.7"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <ComboBox Grid.Row="1"
                              x:Name="StoredTokenComboBox"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              md:HintAssist.Hint="Select account"
                              Height="48"/>
                </Grid>
            </TabItem>

            <!-- Tab 2 – paste a raw access token -->
            <TabItem Header="Custom Token">
                <Grid Margin="8,16,8,8">
                    <TextBox x:Name="CustomTokenBox"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             md:HintAssist.Hint="Paste access token here"
                             FontFamily="Consolas"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             Height="68"
                             VerticalContentAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Inject button -->
        <Button Content="Inject Token"
                Height="44"
                Margin="0,20,0,0"
                md:ButtonAssist.CornerRadius="8"
                HorizontalAlignment="Right"
                Width="160"
                Click="OnInject"/>

    </StackPanel>
</Window>
