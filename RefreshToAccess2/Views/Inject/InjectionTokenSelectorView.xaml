<UserControl x:Class="RefreshToAccess2.Views.Inject.InjectionTokenSelectorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:RefreshToAccess2.Helpers"
        xmlns:loc="clr-namespace:RefreshToAccess2.Localization"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        MinWidth="480" MaxWidth="480">

    <md:DialogHost Identifier="InjTokenDialog" DialogTheme="Inherit">
    <StackPanel Margin="28">

        <!-- Heading -->
        <TextBlock Text="{loc:Tr InjTok.Title}"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   Margin="0,0,0,20"/>

        <!-- Tab control: stored token vs custom token -->
        <TabControl x:Name="SelectorTab"
                    Height="160"
                    md:ColorZoneAssist.Mode="PrimaryMid">

            <!-- Tab 1 – pick from stored alts -->
            <TabItem Header="{loc:Tr InjTok.StoredAccount}">
                <Grid Margin="8,16,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{loc:Tr InjTok.OnlyNonExpired}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.7"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <ComboBox Grid.Row="1"
                              x:Name="StoredTokenComboBox"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              md:HintAssist.Hint="{loc:Tr InjTok.SelectAccount}"
                              Height="48"/>
                </Grid>
            </TabItem>

            <!-- Tab 2 – paste a raw access token -->
            <TabItem Header="{loc:Tr InjTok.CustomToken}">
                <Grid Margin="8,16,8,8">
                    <TextBox x:Name="CustomTokenBox"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             md:HintAssist.Hint="{loc:Tr InjTok.PasteHere}"
                             FontFamily="Consolas"
                             TextWrapping="Wrap"
                             AcceptsReturn="False"
                             Height="68"
                             VerticalContentAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="{loc:Tr Common.Close}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="44" Width="100"
                    Margin="0,0,12,0"
                    Click="OnClose"/>
            <Button Content="{loc:Tr InjTok.InjectToken}"
                    Height="44"
                    md:ButtonAssist.CornerRadius="8"
                    Width="160"
                    helpers:InteractionAnimation.Pop="True"
                    Click="OnInject"/>
        </StackPanel>

    </StackPanel>
    </md:DialogHost>
</UserControl>
