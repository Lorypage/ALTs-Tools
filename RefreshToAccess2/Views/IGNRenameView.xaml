<UserControl x:Class="RefreshToAccess2.Views.IGNRenameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:RefreshToAccess2.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600">

    <UserControl.Resources>
        <!-- Declare both converters locally so no global registration is needed -->
        <helpers:InvertBoolConverter    x:Key="InvertBoolConverter"/>
        <BooleanToVisibilityConverter   x:Key="BoolVis"/>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <!-- Page heading -->
            <RowDefinition Height="Auto"/>
            <!-- Subtitle / guidance -->
            <RowDefinition Height="Auto"/>
            <!-- Name text box -->
            <RowDefinition Height="Auto"/>
            <!-- Rename button + progress indicator -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Heading ── -->
        <TextBlock Grid.Row="0"
                   Text="Rename Minecraft Profile"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,8"/>

        <!-- ── Subtitle ── -->
        <TextBlock Grid.Row="1"
                   Text="Enter the new name you want to use. Names must be 3–16 characters long and contain only letters, digits, or underscores."
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   TextWrapping="Wrap"
                   Opacity="0.7"
                   MaxWidth="480"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,24"/>

        <!-- ── Name input ── -->
        <TextBox Grid.Row="2"
                 Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 md:HintAssist.Hint="New profile name"
                 FontSize="16"
                 MaxLength="16"
                 Width="380"
                 HorizontalAlignment="Left"
                 IsEnabled="{Binding IsBusy,
                             Converter={StaticResource InvertBoolConverter}}"/>

        <!-- ── Action row ── -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <!-- Rename button -->
                <ColumnDefinition Width="Auto"/>
                <!-- Indeterminate progress bar (shown while busy) -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Rename"
                    Width="130" Height="42"
                    md:ButtonAssist.CornerRadius="8"
                    IsEnabled="{Binding IsBusy,
                                Converter={StaticResource InvertBoolConverter}}"
                    Click="OnRenameClicked"/>

            <!-- Indeterminate ProgressBar replaces the spinner PackIcon.
                 Visible only while IsBusy = true.                          -->
            <ProgressBar Grid.Column="1"
                         IsIndeterminate="True"
                         Height="4"
                         VerticalAlignment="Center"
                         Margin="20,0,0,0"
                         Visibility="{Binding IsBusy,
                                      Converter={StaticResource BoolVis}}"/>
        </Grid>
    </Grid>
</UserControl>
