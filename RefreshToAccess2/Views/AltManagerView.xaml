<UserControl x:Class="RefreshToAccess2.Views.AltManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:helpers="clr-namespace:RefreshToAccess2.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             Focusable="True">

    <UserControl.Resources>
        <helpers:InvertBoolConverter x:Key="InvertBool"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- ═══════════════════════════════════════════════════
             CARD TEMPLATE — rounded-corner-clipped ripple + hover
             ═══════════════════════════════════════════════════ -->
        <DataTemplate x:Key="CardTpl">
            <Grid Margin="6" Width="258" Cursor="Hand"
                  MouseLeftButtonUp="OnCardClick">

                <!-- Background shape — also the OpacityMask source for clipping -->
                <Border x:Name="CardBase" CornerRadius="16"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        UseLayoutRounding="True" SnapsToDevicePixels="True"/>

                <!-- Ripple + content: clipped to rounded corners via OpacityMask -->
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=CardBase}"/>
                    </Grid.OpacityMask>

                    <md:Ripple Feedback="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                               HorizontalContentAlignment="Stretch"
                               VerticalContentAlignment="Stretch"
                               Focusable="False">
                        <Grid>
                            <!-- Card content -->
                            <Grid Margin="20,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="5"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Background="{DynamicResource MaterialDesign.Brush.Primary.Light}">
                                        <TextBlock Text="{Binding Initial}"
                                                   FontSize="18" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary.Light.Foreground}"/>
                                    </Border>
                                    <TextBlock Text="{Binding IGN}" FontSize="16" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"
                                               TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Opacity="0.6">
                                    <md:PackIcon Kind="CalendarClock" Width="15" Height="15"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding LoginDate}" FontSize="12"
                                               Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Row="4" Orientation="Horizontal" Opacity="0.42">
                                    <md:PackIcon Kind="Fingerprint" Width="14" Height="14"
                                                 VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding UUIDShort}" FontSize="11"
                                               FontFamily="Consolas" Margin="5,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- Hover darkening overlay -->
                            <Border x:Name="HoverOverlay"
                                    Background="#000000" Opacity="0"
                                    IsHitTestVisible="False"/>
                        </Grid>
                    </md:Ripple>
                </Grid>

                <!-- Border outline (on top, unclipped) -->
                <Border CornerRadius="16" BorderThickness="1" IsHitTestVisible="False"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"/>

                <!-- Selection border -->
                <Border CornerRadius="16" BorderThickness="2.5" IsHitTestVisible="False"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                        Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}"/>

                <!-- Check badge -->
                <Border Width="26" Height="26" CornerRadius="13" IsHitTestVisible="False"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-3,-3,0"
                        Background="{DynamicResource MaterialDesign.Brush.Primary}"
                        Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}">
                    <md:PackIcon Kind="Check" Width="16" Height="16" Foreground="White"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Hover fade triggers -->
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.055" Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Mouse.MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
            </Grid>
        </DataTemplate>

        <!-- ═══════════════════════════════════════════════════
             LIST TEMPLATE — rounded-corner-clipped ripple + hover
             ═══════════════════════════════════════════════════ -->
        <DataTemplate x:Key="ListTpl">
            <Grid Cursor="Hand" MouseLeftButtonUp="OnCardClick"
                  Margin="0,1">

                <!-- Background shape — OpacityMask source -->
                <Border x:Name="ListBase" CornerRadius="12"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        UseLayoutRounding="True" SnapsToDevicePixels="True"/>

                <!-- Ripple + content: clipped to rounded corners -->
                <Grid>
                    <Grid.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=ListBase}"/>
                    </Grid.OpacityMask>

                    <md:Ripple Feedback="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                               HorizontalContentAlignment="Stretch"
                               VerticalContentAlignment="Stretch"
                               Focusable="False">
                        <Grid>
                            <!-- Row content -->
                            <Grid Margin="16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="155"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="34" Height="34" CornerRadius="17"
                                        Background="{DynamicResource MaterialDesign.Brush.Primary.Light}">
                                    <TextBlock Text="{Binding Initial}" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary.Light.Foreground}"/>
                                </Border>

                                <TextBlock Grid.Column="2" Text="{Binding IGN}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="3" Text="{Binding LoginDate}"
                                           FontSize="12.5" Opacity="0.55"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4" Text="{Binding UUIDShort}"
                                           FontSize="11.5" FontFamily="Consolas" Opacity="0.38"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <md:PackIcon Grid.Column="5" Kind="CheckCircle" Width="20" Height="20"
                                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}"/>
                            </Grid>

                            <!-- Hover darkening overlay -->
                            <Border x:Name="ListHover"
                                    Background="#000000" Opacity="0"
                                    IsHitTestVisible="False"/>
                        </Grid>
                    </md:Ripple>
                </Grid>

                <!-- Hover fade triggers -->
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ListHover"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.045" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Mouse.MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="ListHover"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.26">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         ROOT GRID
         ═══════════════════════════════════════════════════════════ -->
    <Grid x:Name="RootGrid" ClipToBounds="True">

        <!-- ▂▂▂  LAYER 1 : Main content ▂▂▂ -->
        <Grid x:Name="MainContentGrid"
              UseLayoutRounding="True" SnapsToDevicePixels="True">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Header -->
                <RowDefinition Height="Auto"/>   <!-- Progress bar -->
                <RowDefinition Height="*"/>      <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ── Header bar ── -->
            <Border Grid.Row="0" Padding="24,18,24,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             md:HintAssist.Hint="Search accounts…"
                             md:TextFieldAssist.HasClearButton="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Width="320" Height="46"
                             VerticalContentAlignment="Center" FontSize="14"/>

                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                               HorizontalAlignment="Left" Opacity="0.50" FontSize="13">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} account(s)">
                                <Binding Path="TotalCount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="38" Margin="0,0,8,0"
                                Click="OnImport" ToolTip="Import profiles (.tapf)">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FileImport" Width="18" Height="18"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Import" Margin="6,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <ToggleButton Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}"
                                      Width="40" Height="40" Margin="4,0"
                                      IsChecked="{Binding IsCardView, Converter={StaticResource InvertBool}}"
                                      ToolTip="Toggle card / list">
                            <md:PackIcon Kind="ListBox" Width="21" Height="21"/>
                            <md:ToggleButtonAssist.OnContent>
                                <md:PackIcon Kind="FormatListBulleted" Width="21" Height="21"/>
                            </md:ToggleButtonAssist.OnContent>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}"
                                      Width="40" Height="40" Margin="4,0"
                                      IsChecked="{Binding IsSelectionMode}"
                                      ToolTip="Toggle selection mode">
                            <md:PackIcon Kind="CheckboxMultipleBlankOutline" Width="21" Height="21"/>
                            <md:ToggleButtonAssist.OnContent>
                                <md:PackIcon Kind="CheckboxMultipleMarked" Width="21" Height="21"/>
                            </md:ToggleButtonAssist.OnContent>
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Search progress bar ── -->
            <Grid Grid.Row="1" Height="4" Margin="24,0">
                <!-- Always present for layout but visibility toggles -->
                <ProgressBar x:Name="SearchProgress"
                             IsIndeterminate="True"
                             Height="4"
                             VerticalAlignment="Top"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                             Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                             Visibility="{Binding IsSearching, Converter={StaticResource BoolVis}}"
                             Opacity="0"/>
            </Grid>

            <!-- ── Scrollable content ── -->
            <Grid Grid.Row="2" Margin="16,0,16,0">

                <!-- Card view -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="4,0,4,80"
                              Visibility="{Binding IsCardView, Converter={StaticResource BoolVis}}">
                    <ItemsControl ItemsSource="{Binding DisplayItems}"
                                  ItemTemplate="{StaticResource CardTpl}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- List view -->
                <ItemsControl ItemsSource="{Binding DisplayItems}"
                              ItemTemplate="{StaticResource ListTpl}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              ScrollViewer.CanContentScroll="True"
                              Visibility="{Binding IsListView, Converter={StaticResource BoolVis}}">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          CanContentScroll="True" Focusable="False"
                                          Padding="4,0,4,80">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolVis}}">
                    <md:PackIcon Kind="AccountGroupOutline" Width="64" Height="64"
                                 HorizontalAlignment="Center" Opacity="0.25"/>
                    <TextBlock Text="No accounts found" FontSize="17" FontWeight="Medium"
                               HorizontalAlignment="Center" Opacity="0.50" Margin="0,14,0,4"/>
                    <TextBlock Text="Import profiles or convert tokens to get started"
                               FontSize="13" HorizontalAlignment="Center" Opacity="0.35"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ▂▂▂  LAYER 2 : Selection action bar ▂▂▂ -->
        <Border x:Name="SelectionBar"
                VerticalAlignment="Bottom"
                Margin="20,0,20,0"
                Padding="24,12"
                CornerRadius="20,20,0,0"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                RenderTransformOrigin="0.5,1"
                UseLayoutRounding="True">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.16" Direction="90"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="BarSlide" Y="120"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Content="Select All" Height="34" FontSize="12.5"
                            Click="OnSelectAll"/>
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Content="Deselect" Height="34" FontSize="12.5"
                            Margin="2,0,0,0" Click="OnDeselectAll"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="DelSelBtn" Click="OnDeleteSelected"
                            Height="38" Margin="0,0,8,0"
                            RenderTransformOrigin="0.5,0.5"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            md:ButtonAssist.CornerRadius="19"
                            Background="{DynamicResource MaterialDesignValidationErrorBrush}"
                            BorderBrush="{DynamicResource MaterialDesignValidationErrorBrush}"
                            Foreground="White">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="DelBtnScale" ScaleX="0" ScaleY="0"/>
                        </Button.RenderTransform>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="DeleteOutline" Width="17" Height="17"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectionLabel}" Margin="5,0,0,0"
                                       VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ExpSelBtn" Click="OnExportSelected"
                            Height="38" Margin="0,0,8,0"
                            RenderTransformOrigin="0.5,0.5"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            md:ButtonAssist.CornerRadius="19">
                        <Button.RenderTransform>
                            <ScaleTransform x:Name="ExpSelScale" ScaleX="0" ScaleY="0"/>
                        </Button.RenderTransform>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FileExportOutline" Width="17" Height="17"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="Export Selected" Margin="5,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="OnExportAll" Height="38" Margin="0,0,8,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            md:ButtonAssist.CornerRadius="19">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="DatabaseExportOutline" Width="17" Height="17"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="Export All" Margin="5,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="OnDeleteAll" Height="38"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            md:ButtonAssist.CornerRadius="19"
                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                            BorderBrush="{DynamicResource MaterialDesignValidationErrorBrush}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="DeleteSweepOutline" Width="17" Height="17"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="Delete All" Margin="5,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ▂▂▂  LAYER 3 : Detail overlay ▂▂▂ -->
        <Grid x:Name="DetailOverlay" Visibility="Collapsed"
              Background="Transparent" Focusable="True"
              KeyDown="OnOverlayKey">

            <Border x:Name="DimBg" Background="#66000000" Opacity="0"
                    MouseLeftButtonDown="OnDimClick"/>

            <Border x:Name="DetailCard"
                    MaxWidth="540" MaxHeight="600"
                    Margin="32"
                    CornerRadius="24" Padding="0"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    UseLayoutRounding="True" SnapsToDevicePixels="True"
                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="28" Opacity="0.24"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform x:Name="CardScale" ScaleX="0.93" ScaleY="0.93"/>
                </Border.RenderTransform>

                <Grid Margin="30,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,-6,-6,0" Width="38" Height="38"
                            Click="OnCloseDetail" ToolTip="Close (Esc)">
                        <md:PackIcon Kind="Close" Width="20" Height="20"/>
                    </Button>

                    <!-- Header: avatar + IGN + date + client -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                        <Border Width="56" Height="56" CornerRadius="28"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource MaterialDesign.Brush.Primary.Light}">
                            <TextBlock Text="{Binding DetailItem.Initial}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Light.Foreground}"/>
                        </Border>
                        <TextBlock Text="{Binding DetailItem.IGN}"
                                   FontSize="21" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,10,0,3"/>
                        <TextBlock HorizontalAlignment="Center" Opacity="0.50" FontSize="12.5">
                            <Run Text="Logged in:"/>
                            <Run Text="{Binding DetailItem.LoginDate, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Center" Opacity="0.42" FontSize="12"
                                   Margin="0,2,0,0">
                            <Run Text="Client:"/>
                            <Run Text="{Binding DetailItem.ClientId, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Fields (no more Client ID card) -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- UUID -->
                            <Border CornerRadius="12" Padding="14,10" Margin="0,0,0,6"
                                    Background="{DynamicResource MaterialDesign.Brush.Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="UUID" FontSize="11" Opacity="0.50"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding DetailItem.UUID}"
                                                   FontSize="12.5" FontFamily="Consolas"
                                                   Margin="0,3,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Tag="UUID" Click="OnCopyField"
                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Width="34" Height="34" ToolTip="Copy UUID">
                                        <md:PackIcon Kind="ContentCopy" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Refresh Token -->
                            <Border CornerRadius="12" Padding="14,10" Margin="0,0,0,6"
                                    Background="{DynamicResource MaterialDesign.Brush.Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Refresh Token" FontSize="11" Opacity="0.50"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding DetailItem.RefShort}"
                                                   FontSize="12.5" FontFamily="Consolas"
                                                   Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Tag="RefToken" Click="OnCopyField"
                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Width="34" Height="34" ToolTip="Copy Refresh Token">
                                        <md:PackIcon Kind="ContentCopy" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Access Token -->
                            <Border CornerRadius="12" Padding="14,10" Margin="0,0,0,6"
                                    Background="{DynamicResource MaterialDesign.Brush.Background}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Access Token" FontSize="11" Opacity="0.50"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding DetailItem.AccShort}"
                                                   FontSize="12.5" FontFamily="Consolas"
                                                   Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Tag="AccToken" Click="OnCopyField"
                                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Width="34" Height="34" ToolTip="Copy Access Token">
                                        <md:PackIcon Kind="ContentCopy" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bottom actions -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Height="40" Padding="18,0"
                                md:ButtonAssist.CornerRadius="20"
                                Click="OnDetailRefresh" ToolTip="Refresh this token via Converter">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Refresh" Width="19" Height="19"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh Token" Margin="7,0,0,0"
                                           VerticalAlignment="Center" FontWeight="Medium"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="40" Padding="18,0" Margin="10,0,0,0"
                                md:ButtonAssist.CornerRadius="20"
                                Click="OnCopyAll" ToolTip="Copy every field">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ContentCopy" Width="17" Height="17"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Copy All" Margin="7,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ▂▂▂  LAYER 4 : Snackbar ▂▂▂ -->
        <md:Snackbar x:Name="Snackbar"
                     VerticalAlignment="Bottom" HorizontalAlignment="Center"
                     Margin="0,0,0,14"/>
    </Grid>
</UserControl>
