<UserControl x:Class="RefreshToAccess2.Views.SkinChangerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RefreshToAccess2.Controls"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:RefreshToAccess2.Helpers"
             xmlns:loc="clr-namespace:RefreshToAccess2.Localization"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <loc:EnumLocalizeConverter x:Key="EnumLoc"/>
        <helpers:InvertBoolConverter x:Key="InvertBool"/>
        <DataTemplate x:Key="EnumItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource EnumLoc}}"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24,20,24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── Left: controls ─── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          helpers:SmoothScroll.IsEnabled="True"
                          Margin="0,0,4,0">
                <StackPanel>

                    <!-- Header — clean type, no gimmicky icon circle -->
                    <TextBlock Text="{loc:Tr Skin.Title}"
                               FontSize="24"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{loc:Tr Skin.Subtitle}"
                               FontSize="13"
                               Opacity="0.58"
                               Margin="0,4,0,24"/>

                    <!-- ── Current account ── -->
                    <Border Padding="16"
                            CornerRadius="12"
                            Background="{DynamicResource MaterialDesignPaper}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{loc:Tr Skin.CurrentAccount}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{loc:Tr Skin.Name}" Opacity="0.50" Margin="0,0,0,3"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding ProfileName}" FontWeight="Medium"
                                           Margin="0,0,0,3"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{loc:Tr Skin.Uuid}" Opacity="0.50" Margin="0,0,0,3"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding ProfileId}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ProfileId}"
                                           Margin="0,0,0,3"/>

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{loc:Tr Skin.Skin}" Opacity="0.50"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding CurrentSkinUrl}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding CurrentSkinUrl}"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="{loc:Tr Skin.Refresh}"
                                        Command="{Binding RefreshProfileCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Height="30" Padding="14,0" FontSize="12"/>
                                <Button Content="{loc:Tr Skin.FetchSkin}"
                                        Command="{Binding FetchPlayerSkinCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- ── Rename (merged from Renamer) ── -->
                            <Separator Opacity="0.25" Margin="0,14,0,12"/>
                            <TextBlock Text="{loc:Tr Skin.Rename}"
                                       FontSize="12" FontWeight="Medium" Opacity="0.58"
                                       Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         md:HintAssist.Hint="{loc:Tr Skin.NewNameHint}"
                                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="16"
                                         VerticalAlignment="Center"
                                         IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"/>
                                <Button Grid.Column="1"
                                        Content="{loc:Tr Skin.RenameButton}"
                                        Command="{Binding RenameCommand}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        VerticalAlignment="Center"
                                        helpers:InteractionAnimation.Pop="True"
                                        Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Find player skin ── -->
                    <Border Padding="16"
                            CornerRadius="12"
                            Background="{DynamicResource MaterialDesignPaper}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{loc:Tr Skin.FindPlayer}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBox md:HintAssist.Hint="{loc:Tr Skin.PlayerNameHint}"
                                     md:TextFieldAssist.HasClearButton="True"
                                     Text="{Binding OtherPlayerName, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Command="{Binding PreviewOtherPlayerSkinCommand}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        helpers:InteractionAnimation.Pop="True">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="Eye" Width="15" Height="15" Margin="0,0,5,0"/>
                                        <TextBlock Text="{loc:Tr Skin.Preview}"/>
                                    </StackPanel>
                                </Button>
                                <Button Content="{loc:Tr Skin.SavePng}"
                                        Command="{Binding DownloadOtherPlayerSkinCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- resolved info -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{loc:Tr Skin.Name}" FontSize="12" Opacity="0.42"
                                           Margin="0,0,0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding OtherPlayerResolvedName}"
                                           FontSize="12" Opacity="0.68"
                                           Margin="0,0,0,2"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{loc:Tr Skin.Uuid}" FontSize="12" Opacity="0.42"
                                           Margin="0,0,0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding OtherPlayerResolvedId}"
                                           FontSize="12" Opacity="0.68"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding OtherPlayerResolvedId}"
                                           Margin="0,0,0,2"/>

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{loc:Tr Skin.Skin}" FontSize="12" Opacity="0.42"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding OtherPlayerSkinUrl}"
                                           FontSize="12" Opacity="0.68"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding OtherPlayerSkinUrl}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Apply skin ── -->
                    <Border Padding="16"
                            CornerRadius="12"
                            Background="{DynamicResource MaterialDesignPaper}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{loc:Tr Skin.ApplySkin}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{loc:Tr Skin.ApplyDesc}"
                                       FontSize="12"
                                       Opacity="0.55"
                                       Margin="0,0,0,12"/>

                            <ComboBox md:HintAssist.Hint="{loc:Tr Skin.VariantHint}"
                                      ItemsSource="{Binding AvailableVariants}"
                                      SelectedItem="{Binding SelectedVariant}"
                                      ItemTemplate="{StaticResource EnumItemTemplate}"
                                      Margin="0,0,0,14"/>

                            <Separator Opacity="0.25" Margin="0,0,0,12"/>

                            <!-- from file -->
                            <TextBlock Text="{loc:Tr Skin.FromFile}"
                                       FontSize="12" FontWeight="Medium" Opacity="0.58"
                                       Margin="0,0,0,8"/>

                            <TextBox md:HintAssist.Hint="{loc:Tr Skin.PathHint}"
                                     Text="{Binding LocalSkinPath, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Button Content="{loc:Tr Skin.Browse}"
                                        Command="{Binding BrowseSkinCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Height="30" Padding="14,0" FontSize="12"/>
                                <Button Content="{loc:Tr Skin.Upload}"
                                        Command="{Binding ApplyFileSkinCommand}"
                                        Height="30" Padding="14,0" FontSize="12"
                                        helpers:InteractionAnimation.Pop="True"
                                        Margin="8,0,0,0"/>
                            </StackPanel>

                            <Separator Opacity="0.25" Margin="0,0,0,12"/>

                            <!-- from URL -->
                            <TextBlock Text="{loc:Tr Skin.FromUrl}"
                                       FontSize="12" FontWeight="Medium" Opacity="0.58"
                                       Margin="0,0,0,8"/>

                            <TextBox md:HintAssist.Hint="{loc:Tr Skin.UrlHint}"
                                     Text="{Binding RemoteSkinUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>

                            <Button Content="{loc:Tr Skin.ApplyUrl}"
                                    Command="{Binding ApplyUrlSkinCommand}"
                                    Height="30" Padding="14,0" FontSize="12"
                                    helpers:InteractionAnimation.Pop="True"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Scene ── -->
                    <Border Padding="16"
                            CornerRadius="12"
                            Background="{DynamicResource MaterialDesignPaper}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            Margin="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="{loc:Tr Skin.Scene}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          md:HintAssist.Hint="{loc:Tr Skin.AnimationHint}"
                                          ItemsSource="{Binding AvailableAnimationModes}"
                                          SelectedItem="{Binding SelectedAnimationMode}"
                                          ItemTemplate="{StaticResource EnumItemTemplate}"/>

                                <ComboBox Grid.Column="2"
                                          md:HintAssist.Hint="{loc:Tr Skin.BackgroundHint}"
                                          ItemsSource="{Binding AvailableBackgroundModes}"
                                          SelectedItem="{Binding SelectedBackgroundMode}"
                                          ItemTemplate="{StaticResource EnumItemTemplate}"/>

                                <ComboBox Grid.Column="4"
                                          md:HintAssist.Hint="{loc:Tr Skin.PanoramaHint}"
                                          ItemsSource="{Binding AvailablePanoramaPresets}"
                                          SelectedItem="{Binding SelectedPanoramaPreset}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="-6,2,0,0">
                                <Button Content="{loc:Tr Skin.ClearPanorama}"
                                        Command="{Binding ClearPanoramaCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="28" Padding="8,0" FontSize="12"/>
                                <Button Content="{loc:Tr Skin.ResetCamera}"
                                        Click="ResetCameraButton_OnClick"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Height="28" Padding="8,0" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Status — pinned outside the scroll, always visible -->
            <StackPanel Grid.Row="1" Margin="0,10,4,0">
                <ProgressBar Height="2"
                             IsIndeterminate="{Binding IsBusy}"
                             Margin="0,0,0,6"/>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Opacity="0.55"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- ─── Right: preview ─── -->
        <Grid Grid.Column="2">
            <Border CornerRadius="16"
                    ClipToBounds="True"
                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                    BorderThickness="1"
                    Background="{DynamicResource MaterialDesignPaper}">
                <controls:MinecraftSkinPreviewControl
                    x:Name="SkinPreview"
                    SkinBytes="{Binding PreviewSkinPng}"
                    SkinVariant="{Binding SelectedVariant}"
                    AnimationMode="{Binding SelectedAnimationMode}"
                    BackgroundMode="{Binding SelectedBackgroundMode}"
                    PanoramaSourcePath="{Binding PanoramaSourcePath}"/>
            </Border>

            <TextBlock Text="{loc:Tr Skin.OrbitHint}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,14"
                       FontSize="11"
                       Opacity="0.35"
                       IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</UserControl>
