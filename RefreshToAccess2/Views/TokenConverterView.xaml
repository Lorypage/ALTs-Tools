<UserControl x:Class="RefreshToAccess2.Views.TokenConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:RefreshToAccess2.Helpers"
             xmlns:loc="clr-namespace:RefreshToAccess2.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="850">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <helpers:InvertBoolConverter  x:Key="InvertBoolConverter"/>

        <Style x:Key="SmallActionButton" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignIconButton}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1.18" Duration="0:0:0.22">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1.18" Duration="0:0:0.22">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0.7" Duration="0:0:0.22"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1" Duration="0:0:0.25"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1" Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="0.85" Duration="0:0:0.08"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="0.85" Duration="0:0:0.08"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1.18" Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1.18" Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TokenFieldStyle" TargetType="TextBox"
               BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="md:HintAssist.FloatingScale" Value="0.82"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <Style x:Key="MicroLabel" TargetType="TextBlock"
               BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.38"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.42"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="36,24,36,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─────────────────────────────────────────────
                 HEADER
                 ───────────────────────────────────────────── -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
           Text="{loc:Tr Converter.Title}"
           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
           Margin="0,0,0,20"/>

                <!-- Mode + Client ID chips -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Conversion mode chip -->
                    <Border VerticalAlignment="Center"
                            CornerRadius="20"
                            Padding="6,0,4,0"
                            Height="40"
                            Margin="0,0,10,0"
                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <md:PackIcon Kind="SwapHorizontal"
                                         Width="16" Height="16"
                                         VerticalAlignment="Center"
                                         Opacity="0.55"
                                         Margin="6,0,8,0"/>
                            <ComboBox SelectedIndex="{Binding SelectedModeIndex}"
                                      Style="{StaticResource MaterialDesignComboBox}"
                                      FontSize="12.5"
                                      MinWidth="150"
                                      BorderThickness="0"
                                      md:HintAssist.Hint="{loc:Tr Converter.ModeHint}"
                                      md:TextFieldAssist.DecorationVisibility="Collapsed"
                                      md:TextFieldAssist.RippleOnFocusEnabled="True"
                                      VerticalAlignment="Center">
                                <ComboBoxItem Content="{loc:Tr Converter.ModeRefresh}"/>
                                <ComboBoxItem Content="{loc:Tr Converter.ModeCookie}"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Client ID chip (refresh-token mode only) -->
                    <Border VerticalAlignment="Center"
                            CornerRadius="20"
                            Padding="6,0,4,0"
                            Height="40"
                            Visibility="{Binding IsRefreshMode, Converter={StaticResource BoolVis}}"
                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <md:PackIcon Kind="ShieldKeyOutline"
                                         Width="16" Height="16"
                                         VerticalAlignment="Center"
                                         Opacity="0.55"
                                         Margin="6,0,8,0"/>
                            <ComboBox SelectedIndex="{Binding SelectedClientIndex}"
                                      SelectionChanged="OnClientSelectionChanged"
                                      Style="{StaticResource MaterialDesignComboBox}"
                                      FontSize="12.5"
                                      MinWidth="130"
                                      BorderThickness="0"
                                      md:HintAssist.Hint="{loc:Tr Converter.ClientIdHint}"
                                      md:TextFieldAssist.DecorationVisibility="Collapsed"
                                      md:TextFieldAssist.RippleOnFocusEnabled="True"
                                      VerticalAlignment="Center">
                            <ComboBoxItem Content="Vanilla"/>
                            <ComboBoxItem Content="HMCL"/>
                            <ComboBoxItem Content="PCL"/>
                            <ComboBoxItem Content="Essential"/>
                            <ComboBoxItem Content="Tzi Checker"/>
                            <ComboBoxItem Content="Mal Checker"/>
                            <ComboBoxItem Content="In-Game Account Switcher"/>
                            <ComboBoxItem Content="ksyz Alt Manager"/>
                            <ComboBoxItem Content="BakaXL"/>
                            <ComboBoxItem Content="LabyMod"/>
                            <ComboBoxItem Content="{loc:Tr Converter.ClientCustom}"/>
                        </ComboBox>
                    </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ─────────────────────────────────────────────
                 MAIN CONTENT — side-by-side tokens
                 ───────────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LEFT: Refresh Token -->
                <md:Card Grid.Column="0" Grid.Row="0"
                         md:ElevationAssist.Elevation="Dp1"
                         UniformCornerRadius="18"
                         Padding="20,18,20,16"
                         VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button Content="{md:PackIcon Kind=ContentPaste, Size=18}"
                                        Style="{StaticResource SmallActionButton}"
                                        ToolTip="{loc:Tr Converter.PasteTip}"
                                        Click="OnPasteRefreshToken"/>
                                <Button Content="{md:PackIcon Kind=BackspaceOutline, Size=17}"
                                        Style="{StaticResource SmallActionButton}"
                                        ToolTip="{loc:Tr Converter.ClearTip}"
                                        Click="OnClearRefreshToken"
                                        Margin="2,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="LoginVariant"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"
                                             Opacity="0.45"
                                             Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding InputSectionLabel}"
                                           Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBox Grid.Row="1"
                                 Text="{Binding RefreshToken, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TokenFieldStyle}"
                                 md:HintAssist.Hint="{Binding InputHint}"
                                 MinHeight="160"
                                 MaxHeight="280"/>

                        <TextBlock Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Margin="0,6,4,0"
                                   FontSize="10.5"
                                   Opacity="0.3"
                                   FontFamily="Cascadia Mono, Consolas">
                            <Run Text="{Binding RefreshToken.Length, Mode=OneWay, FallbackValue=0}"/>
                            <Run Text="{loc:Tr Converter.Chars}"/>
                        </TextBlock>
                    </Grid>
                </md:Card>

                <!-- CENTER: directional hint -->
                <Grid Grid.Column="1" Grid.Row="0"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center">
                    <md:PackIcon Kind="ChevronRight"
                                 Width="22" Height="22"
                                 Opacity="0.18"/>
                </Grid>

                <!-- RIGHT: Access Token -->
                <md:Card Grid.Column="2" Grid.Row="0"
                         md:ElevationAssist.Elevation="Dp1"
                         UniformCornerRadius="18"
                         Padding="20,18,20,16"
                         VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button Content="{md:PackIcon Kind=ContentCopy, Size=18}"
                                        Style="{StaticResource SmallActionButton}"
                                        ToolTip="{loc:Tr Converter.CopyTip}"
                                        Click="OnCopyAccessToken"/>
                                <Button Content="{md:PackIcon Kind=BackspaceOutline, Size=17}"
                                        Style="{StaticResource SmallActionButton}"
                                        ToolTip="{loc:Tr Converter.ClearTip}"
                                        Click="OnClearAccessToken"
                                        Margin="2,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="LogoutVariant"
                                             Width="18" Height="18"
                                             VerticalAlignment="Center"
                                             Opacity="0.45"
                                             Margin="0,0,8,0"/>
                                <TextBlock Text="{loc:Tr Converter.AccessSection}"
                                           Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBox Grid.Row="1"
                                 Text="{Binding AccessToken, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TokenFieldStyle}"
                                 md:HintAssist.Hint="{loc:Tr Converter.AccessHint}"
                                 IsReadOnly="True"
                                 MinHeight="160"
                                 MaxHeight="160"/>

                        <TextBlock Grid.Row="2"
                                   HorizontalAlignment="Right"
                                   Margin="0,6,4,0"
                                   FontSize="10.5"
                                   Opacity="0.3"
                                   FontFamily="Cascadia Mono, Consolas">
                            <Run Text="{Binding AccessToken.Length, Mode=OneWay, FallbackValue=0}"/>
                            <Run Text="{loc:Tr Converter.Chars}"/>
                        </TextBlock>
                    </Grid>
                </md:Card>

                <!-- Profile info strip -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                        Margin="0,16,0,0"
                        CornerRadius="14"
                        Padding="20,14"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- player icon -->
                            <ColumnDefinition Width="*"/>     <!-- player text -->
                            <ColumnDefinition Width="Auto"/>  <!-- copy name btn -->
                            <ColumnDefinition Width="24"/>    <!-- divider gap -->
                            <ColumnDefinition Width="Auto"/>  <!-- uuid icon -->
                            <ColumnDefinition Width="*"/>     <!-- uuid text -->
                            <ColumnDefinition Width="Auto"/>  <!-- copy uuid btn -->
                        </Grid.ColumnDefinitions>

                        <!-- Player icon -->
                        <md:PackIcon Grid.Column="0"
                                     Kind="Account"
                                     Width="18" Height="18"
                                     VerticalAlignment="Center"
                                     Opacity="0.4"
                                     Margin="0,0,10,0"/>

                        <!-- Player text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Tr Converter.Player}"
                                       Style="{StaticResource MicroLabel}"/>
                            <TextBlock Text="{Binding ProfileName, FallbackValue=—}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="13"
                                       Opacity="0.85"/>
                        </StackPanel>

                        <!-- Copy name button (grouped with player, sits before divider) -->
                        <Button Grid.Column="2"
                                Content="{md:PackIcon Kind=ContentCopy, Size=15}"
                                Style="{StaticResource SmallActionButton}"
                                ToolTip="{loc:Tr Converter.CopyNameTip}"
                                Click="OnCopyProfileName"
                                Width="28" Height="28"
                                Margin="8,0,0,0"/>

                        <!-- Vertical divider -->
                        <Border Grid.Column="3"
                                Width="1"
                                VerticalAlignment="Stretch"
                                Margin="0,2"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource MaterialDesignDivider}"
                                Opacity="0.4"/>

                        <!-- UUID icon -->
                        <md:PackIcon Grid.Column="4"
                                     Kind="Fingerprint"
                                     Width="18" Height="18"
                                     VerticalAlignment="Center"
                                     Opacity="0.4"
                                     Margin="0,0,10,0"/>

                        <!-- UUID text -->
                        <StackPanel Grid.Column="5" VerticalAlignment="Center">
                            <TextBlock Text="{loc:Tr Converter.Uuid}"
                                       Style="{StaticResource MicroLabel}"/>
                            <TextBlock Text="{Binding PlayerUuid, FallbackValue=—}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="13"
                                       Opacity="0.85"/>
                        </StackPanel>

                        <!-- Copy UUID button -->
                        <Button Grid.Column="6"
                                Content="{md:PackIcon Kind=ContentCopy, Size=15}"
                                Style="{StaticResource SmallActionButton}"
                                ToolTip="{loc:Tr Converter.CopyUuidTip}"
                                Click="OnCopyUuid"
                                Width="28" Height="28"
                                Margin="8,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────────────────
                 ACTION BAR
                 ───────────────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Height="52"
                        HorizontalAlignment="Stretch"
                        md:ButtonAssist.CornerRadius="14"
                        md:ElevationAssist.Elevation="Dp3"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        helpers:InteractionAnimation.Pop="True"
                        helpers:InteractionAnimation.HoverScale="1.02"
                        FontSize="15"
                        FontWeight="SemiBold"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                        Click="OnConvertClicked">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="SwapHorizontal"
                                     Width="22" Height="22"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ConvertButtonText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Auto-copy toggle -->
                <Border Grid.Column="1"
                        Margin="14,0,0,0"
                        CornerRadius="14"
                        Padding="14,0,10,0"
                        Height="52"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        ToolTip="{loc:Tr Converter.AutoCopyTip}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <md:PackIcon Kind="ContentCopy"
                                     Width="16" Height="16"
                                     Opacity="0.4"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0"/>
                        <TextBlock Text="{loc:Tr Converter.AutoCopy}"
                                   FontSize="12.5"
                                   VerticalAlignment="Center"
                                   Opacity="0.65"
                                   Margin="0,0,12,0"/>
                        <ToggleButton Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding AutoCopyToken}"
                                      VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────────────────
                 STATUS
                 ───────────────────────────────────────────── -->
            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                <ProgressBar IsIndeterminate="True"
                             Height="2"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>

                <TextBlock x:Name="StatusLabel"
                           Text="{Binding StatusMessage}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Opacity="0"
                           FontSize="12.5"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"/>
            </StackPanel>

            <!-- ─────────────────────────────────────────────
                 TOKEN EXPIRY CHECK
                 ───────────────────────────────────────────── -->
            <Border Grid.Row="4"
                    Margin="0,6,0,0"
                    CornerRadius="14"
                    Padding="20,16"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <md:PackIcon Kind="ClockAlertOutline"
                                     Width="18" Height="18"
                                     VerticalAlignment="Center"
                                     Opacity="0.45"
                                     Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Tr Converter.Expiry.Section}"
                                   Style="{StaticResource SectionLabel}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding ExpiryInput, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TokenFieldStyle}"
                                 md:HintAssist.Hint="{loc:Tr Converter.Expiry.InputHint}"
                                 MinHeight="80"
                                 MaxHeight="160"
                                 VerticalAlignment="Top"/>

                        <Button Grid.Column="1"
                                Content="{loc:Tr Converter.Expiry.Check}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                helpers:InteractionAnimation.Pop="True"
                                Height="44"
                                Padding="18,0"
                                md:ButtonAssist.CornerRadius="12"
                                VerticalAlignment="Top"
                                Margin="12,2,0,0"
                                ToolTip="{loc:Tr Converter.Expiry.Tip}"
                                Click="OnCheckExpiry"/>
                    </Grid>

                    <TextBlock Text="{Binding ExpiryResult}"
                               FontSize="13"
                               Opacity="0.85"
                               TextWrapping="Wrap"
                               Margin="2,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
