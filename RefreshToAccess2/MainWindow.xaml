<Window x:Class="RefreshToAccess2.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:RefreshToAccess2.Views"
        xmlns:helpers="clr-namespace:RefreshToAccess2.Helpers"
        xmlns:local="clr-namespace:RefreshToAccess2"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Token Tools For Minecraft 2.1"
        Height="680" Width="1100"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Closing="OnWindowClosing">

    <Window.Resources>
        <DataTemplate DataType="{x:Type local:NavItem}">
            <StackPanel MaxWidth="240">
                <TextBlock FontWeight="SemiBold" 
                           Text="{Binding Label}"/>
                <TextBlock Margin="0,4,0,0" 
                           Opacity="0.82" 
                           Text="{Binding Description}" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter"/>

        <x:Array x:Key="NavItems" Type="{x:Type local:NavItem}">
            <local:NavItem Label="Converter"
                           IconTooltip="Open Token Converter"
                           SelectedIcon="KeyVariant"
                           UnselectedIcon="Key"/>
            <local:NavItem Label="AltManager"
                           IconTooltip="Open Alt Manager"
                           SelectedIcon="AccountMultiple"
                           UnselectedIcon="Account"/>
            <local:NavItem Label="Renamer"
                           IconTooltip="Open IGN Rename"
                           SelectedIcon="AccountEdit"
                           UnselectedIcon="AccountEdit"/>
            <local:NavItem Label="Injector"
                           IconTooltip="Open Token Injector"
                           SelectedIcon="Needle"
                           UnselectedIcon="Needle"/>
            <local:NavItem Label="Skin Changer"
               IconTooltip="Open Skin Changer"
               SelectedIcon="AccountBox"
               UnselectedIcon="AccountBoxOutline"/>
        </x:Array>

        <DataTemplate x:Key="NavRailItemTemplate" DataType="{x:Type local:NavItem}">
            <TextBlock x:Name="LabelTextBlock"
                       Text="{Binding Label}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="13"
                       FontWeight="Medium"
                       Opacity="0"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TranslateTransform Y="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>

            <DataTemplate.Triggers>
                <!-- Fade IN when Expanded -->
                <DataTrigger Binding="{Binding IsRailExpanded, ElementName=MainWindowRoot}" Value="False">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="LabelTextBlock" 
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.25" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="LabelTextBlock" 
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavColumn" Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Material 3 Navigation Rail -->
        <Grid Grid.Column="0"
              Background="{DynamicResource MaterialDesign.Brush.Background}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    x:Name="ToggleRailButton"
                    Width="56"
                    Height="56"
                    Margin="0,12,0,20"
                    HorizontalAlignment="Center"
                    Click="OnToggleRail"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="Toggle navigation labels">
                <md:PackIcon x:Name="ToggleIcon"
                             Kind="Menu"
                             Width="24"
                             Height="24"/>
            </Button>

            <Viewbox Grid.Row="1"
                     VerticalAlignment="Top"
                     Stretch="Uniform">
                <ListBox x:Name="NavListBox"
                         Width="80"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemTemplate="{StaticResource NavRailItemTemplate}"
                         ItemsSource="{StaticResource NavItems}"
                         SelectedIndex="0"
                         SelectionChanged="NavListBox_OnSelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem"
                               BasedOn="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}">
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <ToolTip>
                                        <TextBlock Text="{Binding IconTooltip}"/>
                                    </ToolTip>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="md:NavigationRailAssist.IsTextVisible"
                                    Value="{Binding IsRailExpanded, ElementName=MainWindowRoot}"/>
                            <Setter Property="md:NavigationRailAssist.SelectedIcon" 
                                    Value="{Binding SelectedIcon}"/>
                            <Setter Property="md:NavigationRailAssist.UnselectedIcon" 
                                    Value="{Binding UnselectedIcon}"/>

                            <Setter Property="ToolTipService.ShowDuration" Value="5000"/>
                            <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
                            <Setter Property="ToolTipService.BetweenShowDelay" Value="100"/>
                            <Setter Property="ToolTipService.Placement" Value="Right"/>
                            <Setter Property="ToolTipService.HorizontalOffset" Value="12"/>
                            <Setter Property="ToolTipService.VerticalOffset" Value="0"/>
                            <Setter Property="ToolTip">
                                <Setter.Value>
                                    <ToolTip>
                                        <TextBlock Text="{Binding IconTooltip}"/>
                                    </ToolTip>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Viewbox>
        </Grid>

        <!-- Page content -->
        <Grid Grid.Column="1">

            <views:TokenConverterView
                x:Name="ConverterView"
                DataContext="{Binding Converter}"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:TokenConverterView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:TokenConverterView.RenderTransform>
            </views:TokenConverterView>

            <views:AltManagerView
                x:Name="AltManagerView"
                DataContext="{Binding AltManager}"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:AltManagerView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:AltManagerView.RenderTransform>
            </views:AltManagerView>

            <views:IGNRenameView
                x:Name="IGNRenameView"
                DataContext="{Binding IGNRename}"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:IGNRenameView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:IGNRenameView.RenderTransform>
            </views:IGNRenameView>

            <views:TokenInjectorView
                x:Name="InjectorView"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:TokenInjectorView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:TokenInjectorView.RenderTransform>
            </views:TokenInjectorView>

            <views:SkinChangerView
    x:Name="SkinChangerView"
    DataContext="{Binding SkinChanger}"
    Visibility="Collapsed"
    RenderTransformOrigin="0.5,0.5">
                <views:SkinChangerView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:SkinChangerView.RenderTransform>
            </views:SkinChangerView>

        </Grid>
    </Grid>
</Window>
