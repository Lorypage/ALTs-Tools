<Window x:Class="RefreshToAccess2.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:RefreshToAccess2.Views"
        xmlns:helpers="clr-namespace:RefreshToAccess2.Helpers"
        xmlns:loc="clr-namespace:RefreshToAccess2.Localization"
        xmlns:local="clr-namespace:RefreshToAccess2"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{StaticResource AppFont}"
        TextElement.FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        Title="{loc:Tr Window.Title}"
        Icon="pack://application:,,,/coolpig.ico"
        Height="680" Width="1235"
        MinHeight="600" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="OnSourceInitialized"
        PreviewKeyDown="OnPreviewKeyDown"
        StateChanged="OnWindowStateChanged"
        Closing="OnWindowClosing">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type local:NavItem}">
            <StackPanel MaxWidth="240">
                <TextBlock FontWeight="SemiBold" 
                           Text="{Binding Label}"/>
                <TextBlock Margin="0,4,0,0" 
                           Opacity="0.82" 
                           Text="{Binding Description}" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <helpers:InvertBoolConverter x:Key="InvertBoolConverter"/>

        <!-- Caption (window control) buttons: flat, square, hover-highlight.
             WindowChrome.IsHitTestVisibleInChrome lets clicks through the
             transparent drag region down to these buttons. -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource MaterialDesign.Brush.Card.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseCaptionButton" TargetType="Button"
               BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <md:PackIcon x:Name="Icon"
                                         Kind="Close"
                                         Width="16" Height="16"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E81123"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <x:Array x:Key="NavItems" Type="{x:Type local:NavItem}">
            <local:NavItem LabelKey="Nav.Converter"
                           TooltipKey="Nav.Converter.Tip"
                           SelectedIcon="KeyVariant"
                           UnselectedIcon="Key"/>
            <local:NavItem LabelKey="Nav.AltManager"
                           TooltipKey="Nav.AltManager.Tip"
                           SelectedIcon="AccountMultiple"
                           UnselectedIcon="Account"/>
            <local:NavItem LabelKey="Nav.Injector"
                           TooltipKey="Nav.Injector.Tip"
                           SelectedIcon="Needle"
                           UnselectedIcon="Needle"/>
            <local:NavItem LabelKey="Nav.SkinChanger"
               TooltipKey="Nav.SkinChanger.Tip"
               SelectedIcon="AccountBox"
               UnselectedIcon="AccountBoxOutline"/>
            <local:NavItem LabelKey="Nav.Settings"
               TooltipKey="Nav.Settings.Tip"
               SelectedIcon="Cog"
               UnselectedIcon="CogOutline"/>
        </x:Array>

        <DataTemplate x:Key="NavRailItemTemplate" DataType="{x:Type local:NavItem}">
            <TextBlock x:Name="LabelTextBlock"
                       Text="{Binding Label}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="13"
                       FontWeight="Medium"
                       Opacity="0"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TranslateTransform Y="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>

            <DataTemplate.Triggers>
                <!-- Fade IN when Expanded -->
                <DataTrigger Binding="{Binding IsRailExpanded, ElementName=MainWindowRoot}" Value="False">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="LabelTextBlock" 
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.25" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="LabelTextBlock" 
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <md:DialogHost Identifier="RootDialog"
                   DialogTheme="Inherit"
                   CloseOnClickAway="False">
    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ───── Custom title bar (drag region + caption buttons) ───── -->
        <Grid Grid.Row="0"
              x:Name="TitleBar"
              Background="{DynamicResource MaterialDesign.Brush.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App identity -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center">
                <Image Source="pack://application:,,,/coolpig.ico"
                       Width="18" Height="18"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="{loc:Tr Window.Title}"
                           Margin="10,0,0,0"
                           FontSize="12.5"
                           FontWeight="Medium"
                           Opacity="0.75"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Caption buttons -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource CaptionButton}"
                        Click="OnMinimizeClick"
                        ToolTip="{loc:Tr Window.Minimize}">
                    <md:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                </Button>
                <Button x:Name="MaximizeButton"
                        Style="{StaticResource CaptionButton}"
                        Click="OnMaximizeClick"
                        ToolTip="{loc:Tr Window.Maximize}">
                    <md:PackIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="15" Height="15"/>
                </Button>
                <Button x:Name="CloseButton"
                        Style="{StaticResource CloseCaptionButton}"
                        Click="OnCloseClick"
                        ToolTip="{loc:Tr Window.Close}"/>
            </StackPanel>
        </Grid>

        <!-- ───── App body ───── -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavColumn" Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Material 3 Navigation Rail -->
        <Grid Grid.Column="0"
              Background="{DynamicResource MaterialDesign.Brush.Background}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                    x:Name="ToggleRailButton"
                    Width="56"
                    Height="56"
                    Margin="0,12,0,20"
                    HorizontalAlignment="Center"
                    Click="OnToggleRail"
                    Style="{StaticResource MaterialDesignIconButton}"
                    ToolTip="{loc:Tr Nav.ToggleLabels}">
                <md:PackIcon x:Name="ToggleIcon"
                             Kind="Menu"
                             Width="24"
                             Height="24"/>
            </Button>

            <ListBox Grid.Row="1"
                     x:Name="NavListBox"
                     Width="80"
                     VerticalAlignment="Top"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemTemplate="{StaticResource NavRailItemTemplate}"
                     ItemsSource="{StaticResource NavItems}"
                     SelectedIndex="0"
                     SelectionChanged="NavListBox_OnSelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem"
                               BasedOn="{StaticResource MaterialDesign3.NavigationRailPrimaryListBoxItem}">
                        <Setter Property="helpers:NavPillAnimation.IsEnabled" Value="True"/>
                        <Setter Property="md:RippleAssist.IsDisabled" Value="True"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="md:NavigationRailAssist.IsTextVisible"
                                    Value="{Binding IsRailExpanded, ElementName=MainWindowRoot}"/>
                        <Setter Property="md:NavigationRailAssist.SelectedIcon"
                                    Value="{Binding SelectedIcon}"/>
                        <Setter Property="md:NavigationRailAssist.UnselectedIcon"
                                    Value="{Binding UnselectedIcon}"/>
                        <Setter Property="ToolTipService.ShowDuration" Value="5000"/>
                        <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
                        <Setter Property="ToolTipService.BetweenShowDelay" Value="100"/>
                        <Setter Property="ToolTipService.Placement" Value="Right"/>
                        <Setter Property="ToolTipService.HorizontalOffset" Value="12"/>
                        <Setter Property="ToolTipService.VerticalOffset" Value="0"/>
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                <ToolTip>
                                    <TextBlock Text="{Binding IconTooltip}"/>
                                </ToolTip>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <!-- Page content -->
        <Grid Grid.Column="1">

            <views:TokenConverterView
                x:Name="ConverterView"
                DataContext="{Binding Converter}"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:TokenConverterView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:TokenConverterView.RenderTransform>
            </views:TokenConverterView>

            <views:AltManagerView
                x:Name="AltManagerView"
                DataContext="{Binding AltManager}"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:AltManagerView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:AltManagerView.RenderTransform>
            </views:AltManagerView>

            <views:TokenInjectorView
                x:Name="InjectorView"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:TokenInjectorView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:TokenInjectorView.RenderTransform>
            </views:TokenInjectorView>

            <views:SkinChangerView
    x:Name="SkinChangerView"
    DataContext="{Binding SkinChanger}"
    Visibility="Collapsed"
    RenderTransformOrigin="0.5,0.5">
                <views:SkinChangerView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:SkinChangerView.RenderTransform>
            </views:SkinChangerView>

            <views:SettingsView
                x:Name="SettingsView"
                DataContext="{Binding Settings}"
                Visibility="Collapsed"
                RenderTransformOrigin="0.5,0.5">
                <views:SettingsView.RenderTransform>
                    <TranslateTransform Y="0"/>
                </views:SettingsView.RenderTransform>
            </views:SettingsView>

        </Grid>
    </Grid>
    </Grid>
    </md:DialogHost>
</Window>
